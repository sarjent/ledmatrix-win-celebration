{
  "id": "win-celebration",
  "name": "Win Celebration",
  "version": "1.2.0",
  "description": "Displays animated GIF celebrations when configured teams win. Supports multiple teams with per-team GIFs, brand colors, and custom win messages. Works with MLB, NFL, NBA, and NHL via the ESPN public API.",
  "author": "sarjent",
  "homepage": "https://github.com/sarjent/ledmatrix-win-celebration",
  "entry_point": "manager.py",
  "class_name": "WinCelebrationPlugin",
  "category": "sports",
  "tags": [
    "sports",
    "celebration",
    "animation",
    "win",
    "mlb",
    "nfl",
    "nba",
    "nhl",
    "gif"
  ],
  "icon": "fas fa-trophy",
  "compatible_versions": [
    ">=1.0.0"
  ],
  "min_ledmatrix_version": "1.0.0",
  "max_ledmatrix_version": "3.0.0",
  "requires": {
    "python": ">=3.9"
  },
  "config_schema": "config_schema.json",
  "requirements_file": "requirements.txt",
  "update_interval": 300,
  "display_modes": [
    "win_celebration"
  ],
  "api_requirements": [
    {
      "name": "ESPN Scoreboard API",
